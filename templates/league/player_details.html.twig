<!DOCTYPE html>
<html lang="en" class="h-full bg-slate-950 text-slate-100">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>{{ player.name }} | Tournament Breakdown</title>
    <link rel="icon" type="image/x-icon" href="/assets/favicon.svg">
    {% block stylesheets %}
        {{ encore_entry_link_tags('app') }}
        <link rel="stylesheet" href="{{ asset('styles/app.css') }}">
    {% endblock %}
</head>
<body class="min-h-full font-sans antialiased selection:bg-cyan-500 selection:text-slate-950">

<div class="h-2 bg-gradient-to-r from-cyan-500 via-amber-500 to-red-500"></div>

<main class="max-w-5xl mx-auto px-4 py-12 md:py-20">

    <div class="mb-6 text-left">
        <a href="{{ path('season_leaderboard', {'slug': current_season.slug}) }}">
            ⬅ Return to {{ current_season.name }} Leaderboard
        </a>
    </div>

    <header class="text-center mb-12 space-y-2">
        <span class="inline-flex items-center gap-1.5 px-3 py-1 rounded-full text-xs font-semibold bg-cyan-500/10 text-cyan-400 ring-1 ring-inset ring-cyan-500/20 tracking-wider uppercase">
            Blader Performance Profile
        </span>
        <h1 class="text-4xl font-black tracking-tight text-white uppercase">{{ player.name }}</h1>
        <p class="text-slate-400 text-sm">Reviewing individual tournament contributions (Top 14 Limit)</p>
    </header>

    <div class="bg-slate-900 border border-slate-800 rounded-3xl p-4 sm:p-8 shadow-2xl w-full">
        <div class="overflow-x-auto">
            <table class="w-full text-left text-sm border-collapse">
                <thead>
                <tr class="border-b border-slate-800 text-xs font-bold uppercase tracking-wider text-slate-400 bg-slate-950/40">
                    <th class="px-3 sm:px-6 py-4">Tournament</th>
                    <th class="px-3 sm:px-6 py-4 text-center">Date Held</th>
                    <th class="px-3 sm:px-6 py-4 text-center">Base F1 Pts</th>
                    <th class="px-3 sm:px-6 py-4 text-center">KO/Bonus Pts</th>
                    <th class="px-3 sm:px-6 py-4 text-right text-cyan-400 font-bold pr-4">Total</th>
                </tr>
                </thead>
                <tbody class="divide-y divide-slate-800/40 text-slate-300 font-medium">
                {% for match in contributions %}
                    <tr class="hover:bg-slate-800/30 transition-colors">
                        <td class="px-3 sm:px-6 py-4">
                            <a href="{{ path('tournament_details', {'slug': current_season.slug, 'id': match.tournament_id}) }}" class="text-white font-bold hover:text-cyan-400 focus:text-cyan-400 outline-none transition-colors">
                                {{ match.tournament_name }}
                            </a>
                        </td>
                        <td class="px-3 sm:px-6 py-4 text-center font-mono text-xs text-slate-400">{{ match.held_on|date('Y-m-d') }}</td>
                        <td class="px-3 sm:px-6 py-4 text-center text-slate-300">{{ match.f1_points }}</td>
                        <td class="px-3 sm:px-6 py-4 text-center">
                            {% if match.bonus_points > 0 %}
                                <span class="text-emerald-400 font-extrabold text-xs">+{{ match.bonus_points }}</span>
                            {% else %}
                                <span class="text-slate-600">—</span>
                            {% endif %}
                        </td>
                        <td class="px-3 sm:px-6 py-4 text-right font-black text-white pr-4">{{ match.total_points }} <span class="text-xs font-normal text-slate-500">pts</span></td>
                    </tr>
                {% else %}
                    <tr>
                        <td colspan="5" class="px-3 sm:px-6 py-12 text-center text-sm text-slate-500 italic"> No registered records under active seasonal criteria.</td>
                    </tr>
                {% endfor %}
                </tbody>
            </table>
        </div>
    </div>

</main>
</body>
</html>
