<!DOCTYPE html>
<html lang="en" class="h-full bg-slate-950 text-slate-100">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" class="w-full" content="width=device-width, initial-scale=1.0">
    <title>Malta Beyblade Community League | Season 1 Framework</title>
    <link rel="icon" type="image/x-icon" href="/assets/favicon.svg">

    {% block stylesheets %}
        {{ encore_entry_link_tags('app') }}
        <link rel="stylesheet" href="{{ asset('styles/app.css') }}">
    {% endblock %}
</head>
<body class="min-h-full font-sans antialiased selection:bg-cyan-500 selection:text-slate-950">

<div class="h-2 bg-gradient-to-r from-cyan-500 via-amber-500 to-red-500"></div>

<main class="max-w-5xl mx-auto px-4 py-12 md:py-20">

    <header class="text-center mb-16 space-y-4">
        <span class="inline-flex items-center gap-1.5 px-3 py-1 rounded-full text-xs font-semibold bg-cyan-500/10 text-cyan-400 ring-1 ring-inset ring-cyan-500/20 tracking-wider uppercase">
            Official League Framework
        </span>
        <h1 class="text-4xl md:text-6xl font-black tracking-tight text-white uppercase">
            Malta Community Beyblade <br class="hidden sm:inline">
            <span class="text-gradient bg-clip-text text-transparent bg-gradient-to-r from-cyan-400 to-blue-500">MBC League Season 1</span>
        </h1>
        For <strong>the players</strong> By <strong>the players</strong>
    </header>

    <div class="grid grid-cols-1 md:grid-cols-3 gap-6 mb-12">

        <div class="md:col-span-2 relative overflow-hidden rounded-2xl bg-slate-900 border border-slate-800 p-6 sm:p-8 shadow-xl flex flex-col justify-between">
            <div class="absolute top-0 right-0 -mt-4 -mr-4 w-24 h-24 bg-cyan-500/10 rounded-full blur-xl"></div>
            <div>
                <h3 class="text-xs font-bold uppercase text-slate-400 tracking-widest mb-2">Duration</h3>
                <h2 class="text-2xl md:text-3xl font-black text-white mb-4">Season Timeline</h2>
                <div class="flex flex-col sm:flex-row sm:items-center justify-between gap-4 bg-slate-950/60 p-4 rounded-xl border border-slate-800/50">
                    <div>
                        <p class="text-xs uppercase font-bold text-cyan-400">Start Date</p>
                        <p class="text-xl font-extrabold text-white">4 July 2026</p>
                    </div>
                    <div class="hidden sm:block text-slate-600 font-bold">➔</div>
                    <div>
                        <p class="text-xs uppercase font-bold text-red-400">Conclusion</p>
                        <p class="text-xl font-extrabold text-white">4 November 2026</p>
                    </div>
                </div>
            </div>
        </div>

        <div class="rounded-2xl bg-gradient-to-b from-amber-500/10 to-transparent border border-amber-500/20 p-6 sm:p-8 shadow-xl flex flex-col justify-between gap-6">
            <div>
                <h3 class="text-xs font-bold uppercase text-amber-400 tracking-widest mb-2">Registration</h3>
                <h2 class="text-2xl font-black text-white mb-2">Entry Fee Price</h2>
            </div>
            <div class="my-2">
                <span class="text-5xl font-black text-white">20 Euro</span>
                <span class="text-sm font-semibold text-slate-400 block mt-1">Per Blader for Season 1</span>
            </div>
            <div class="text-xs text-amber-300/80 font-medium leading-relaxed bg-amber-500/5 border border-amber-500/10 p-3 rounded-lg">
                📝 <strong>Sign-Ups</strong> Open before and during month 1 of the season.
            </div>
        </div>

    </div>

    <!-- Preseason Standings Callout Box to Hype Up Players -->
    <div class="mb-12 relative overflow-hidden rounded-2xl bg-gradient-to-r from-amber-500/10 via-red-500/10 to-transparent border border-amber-500/20 p-6 sm:p-8 shadow-xl flex flex-col sm:flex-row sm:items-center sm:justify-between gap-6 group">
        <div class="space-y-2">
            <span class="inline-flex items-center gap-1.5 px-2 py-0.5 rounded-full text-[10px] font-bold bg-amber-500/10 text-amber-400 ring-1 ring-inset ring-amber-500/20 tracking-wider uppercase">
                Live Simulation
            </span>
            <h2 class="text-xl sm:text-2xl font-black text-white uppercase tracking-tight">Track Your Preseason Status</h2>
            <p class="text-sm text-slate-400 max-w-xl">See how recent tournament scores convert directly into official league points distributions! Check positions, bonuses, and current standings.</p>
        </div>
        <a href="/preseason" class="inline-flex items-center justify-center gap-2 px-5 py-3 rounded-xl bg-gradient-to-r from-amber-500 to-red-500 font-extrabold text-sm text-slate-950 uppercase tracking-wider hover:brightness-110 active:scale-98 transition-all whitespace-nowrap shadow-lg shadow-red-500/10 group-hover:shadow-red-500/20">
            Visit Preseason Leaderboard ➔
        </a>
    </div>

    <div class="space-y-6 mb-12">

        <div class="bg-slate-900 border border-slate-800 rounded-2xl p-6 sm:p-8 md:p-12 shadow-xl w-full">
            <h2 class="text-2xl font-black text-white mb-8 pb-2 border-b border-slate-800/60 flex items-center gap-2.5">
                <span class="w-3 h-3 rounded-full bg-cyan-500 shadow-[0_0_10px_rgba(6,182,212,0.5)]"></span>
                Points & Standings System
            </h2>

            <div class="grid grid-cols-1 md:grid-cols-3 gap-6 mb-8">
                <div class="flex flex-col gap-3 bg-slate-950/50 p-6 rounded-xl border border-slate-800/40 hover:border-slate-800 transition-colors">
                    <h3 class="font-extrabold text-white text-base mb-1.5"><span class="text-3xl">🏎️</span> Points Allocation</h3>
                    <p class="text-slate-300 text-sm leading-relaxed">Calculated from your <strong>best 14 tournaments</strong> held throughout season 1.</p>
                </div>
                <div class="flex flex-col gap-3 bg-slate-950/50 p-6 rounded-xl border border-slate-800/40 hover:border-slate-800 transition-colors">
                    <h3 class="font-extrabold text-white text-base mb-1.5"><span class="text-3xl">📊</span> Formula One Inspired Structure</h3>
                    <p class="text-slate-300 text-sm leading-relaxed">Points system tracks 1st to 10th place points to determine competitive distributions.</p>
                </div>
                <div class="flex flex-col gap-3 bg-slate-950/50 p-6 rounded-xl border border-slate-800/40 hover:border-slate-800 transition-colors">
                    <h3 class="font-extrabold text-white text-base mb-1.5"><span class="text-3xl">🏆</span> Determining the Winner</h3>
                    <p class="text-slate-300 text-sm leading-relaxed">The player with the most points at the end of the season from his/her best 14 tournaments will be the Winner (1<sup>st</sup>).</p>
                </div>
            </div>

            <div class="bg-slate-950 border border-slate-800 p-4 rounded-xl mb-6 text-sm text-slate-300 leading-relaxed space-y-3">
                <p>🔍 <strong class="text-white">Points Extraction:</strong> Points will be extracted from the swiss scoreboards using the slightly amended Formula One matrix for the top 10 players in the Swiss stage.</p>

                <div class="h-px bg-slate-800/60 my-2"></div>

                <p>⚡ <strong class="text-white">Knockout Stage Bonus:</strong> Players who successfully advance to the knockout stage earn an opportunity to gain <span class="text-amber-400 font-bold">10 additional points</span> on top of the points earned from the swiss standings, plus the standard tournament prizes of the day.</p>

                <div class="h-px bg-slate-800/60 my-2"></div>

                <p>📋 <strong class="text-white">Tournament Formats:</strong> While <strong>Swiss + knockout tournaments</strong> are heavily encouraged as the fairest form of competition, Swiss-only tournaments will also be included <u>as long as the minimum number of 10 players is met.</u></p>
            </div>

            <details class="group bg-slate-950 border border-slate-800/80 rounded-xl cursor-pointer transition-all duration-200 open:ring-1 open:ring-cyan-500/30">
                <summary class="flex justify-between items-center text-xs font-bold tracking-wider uppercase text-cyan-400 list-none select-none p-4 sm:p-5 hover:text-cyan-300 hover:bg-slate-900/40 transition-colors rounded-xl group-open:rounded-b-none group-open:border-b group-open:border-slate-800">
                    <div class="flex items-center gap-2">
                        <span>📊</span>
                        <span>View F1 Points Allocation Matrix</span>
                    </div>
                    <span class="text-slate-500 group-open:rotate-180 transition-transform duration-200 text-xs">▼</span>
                </summary>

                <div class="p-6 sm:p-8 bg-slate-950/40 rounded-b-xl">
                    <div class="max-w-xl mx-auto bg-slate-900/60 border border-slate-800/80 rounded-xl overflow-hidden shadow-2xl">
                        <div class="px-6 py-4 bg-slate-900 border-b border-slate-800/60">
                            <h4 class="text-sm font-bold text-white tracking-wide">F1 Points System Overview</h4>
                            <p class="text-xs text-slate-400 mt-1">Point breakdown structure per tournament finishing placement:</p>
                        </div>

                        <table class="w-full text-left text-sm">
                            <thead>
                            <tr class="border-b border-slate-800 text-xs font-bold uppercase tracking-wider text-slate-400 bg-slate-950/40">
                                <th class="px-6 py-3">Position</th>
                                <th class="px-6 py-3 text-right">Championship Points</th>
                            </tr>
                            </thead>
                            <tbody class="divide-y divide-slate-800/40 text-slate-300 font-medium">
                            <tr class="hover:bg-slate-800/30 transition-colors"><td class="px-6 py-3 text-white font-bold">1st Place</td><td class="px-6 py-3 text-right text-amber-400 font-black text-base">25 points</td></tr>
                            <tr class="hover:bg-slate-800/30 transition-colors"><td class="px-6 py-3">2nd Place</td><td class="px-6 py-3 text-right font-bold text-slate-200">20 points *</td></tr>
                            <tr class="hover:bg-slate-800/30 transition-colors"><td class="px-6 py-3">3rd Place</td><td class="px-6 py-3 text-right font-bold text-amber-600">15 points</td></tr>
                            <tr class="hover:bg-slate-800/30 transition-colors"><td class="px-6 py-3">4th Place</td><td class="px-6 py-3 text-right">12 points</td></tr>
                            <tr class="hover:bg-slate-800/30 transition-colors"><td class="px-6 py-3">5th Place</td><td class="px-6 py-3 text-right">10 points</td></tr>
                            <tr class="hover:bg-slate-800/30 transition-colors"><td class="px-6 py-3">6th Place</td><td class="px-6 py-3 text-right">8 points</td></tr>
                            <tr class="hover:bg-slate-800/30 transition-colors"><td class="px-6 py-3">7th Place</td><td class="px-6 py-3 text-right">6 points</td></tr>
                            <tr class="hover:bg-slate-800/30 transition-colors"><td class="px-6 py-3">8th Place</td><td class="px-6 py-3 text-right">4 points</td></tr>
                            <tr class="hover:bg-slate-800/30 transition-colors"><td class="px-6 py-3">9th Place</td><td class="px-6 py-3 text-right">2 points</td></tr>
                            <tr class="hover:bg-slate-800/30 transition-colors"><td class="px-6 py-3">10th Place</td><td class="px-6 py-3 text-right text-cyan-400 font-bold">1 points</td></tr>
                            </tbody>
                        </table>
                    </div>
                </div>
            </details>
        </div>

        <div class="grid grid-cols-1 md:grid-cols-2 gap-6">

            <div class="bg-slate-900 border border-slate-800 rounded-2xl p-6 sm:p-8 shadow-md flex flex-col justify-between gap-4">
                <div>
                    <h2 class="text-lg font-bold text-white mb-4 flex items-center gap-2">
                        <span class="w-2 h-2 rounded-full bg-red-500"></span>
                        Eligible Format & Styles
                    </h2>
                    <p class="text-sm text-slate-300 leading-relaxed mb-3">
                        To maintain standard ranking integrity, only official events matching these precise configurations qualify:
                    </p>
                </div>
                <div class="p-4 bg-slate-950 rounded-xl border border-slate-800 text-sm space-y-2">
                    <div class="flex flex-col gap-1">
                        <span class="text-xs text-slate-400 uppercase font-bold">Tournaments Eligible</span>
                        <span class="font-semibold text-white">Open Gamesplus and Open Gamebreaker tournaments of a minimum of 10 players or more.</span>
                        <span class="font-semibold text-white">Any other eligible tournaments will be communicated from before the tournament starts.</span>
                    </div>
                    <div class="h-px bg-slate-800 my-1"></div>
                    <div class="flex flex-col gap-1">
                        <span class="text-xs text-slate-400 uppercase font-bold">Tournament Styles Allowed</span>
                        <span class="font-semibold text-amber-400">Swiss + Knockout encouraged but not enforced</span>
                        <span class="font-semibold text-amber-400">The main hard requirements are the minimum of 10 players, and that the tournament must be open to all players
                        and not limited by any means.</span>
                    </div>
                </div>
            </div>

            <div class="bg-slate-900 border border-slate-800 rounded-2xl p-6 sm:p-8 shadow-md flex flex-col justify-between gap-4">
                <div>
                    <h2 class="text-lg font-bold text-white mb-4 flex items-center gap-2">
                        <span class="w-2 h-2 rounded-full bg-emerald-500"></span>
                        Entry Fee Usage & Prizes
                    </h2>
                    <p class="text-sm text-slate-300 leading-relaxed">
                        Every single euro collected via registration fees remains completely inside the competitive community framework.
                    </p>
                </div>

                <div class="space-y-3">
                    <div class="flex items-start gap-2 text-sm bg-slate-950/40 p-3 rounded-xl border border-slate-800/50">
                        <span class="text-emerald-400 font-bold">✓</span>
                        <p class="text-slate-300">
                            <strong class="text-white">Entry fee usage:</strong> Full usage all the entry fees collected will be used as prizes + trophy + sponsorships or contributions from stores.
                        </p>
                    </div>
                    <div class="flex items-start gap-2 text-sm bg-slate-950/40 p-3 rounded-xl border border-slate-800/50">
                        <span class="text-emerald-400 font-bold">✓</span>
                        <p class="text-slate-300">
                            <strong class="text-white">Prize Allocation:</strong> Structured payouts across positions <span class="text-white font-semibold">1st -5th place</span> at the end of the season framework.
                        </p>
                    </div>
                </div>
            </div>

        </div>

    </div>

    <!-- Tentative Player List Section -->
    {% set tentative_bladers = [
        'Derius', 'Giglio', 'Kemical', 'Obelix', 'L-anzjan',
        'Mezz', 'il-karm', 'Shadowblade', 'Beastblade',
        'Markulegend', 'Il-butcher', 'Faenza', 'il-belti'
    ] %}

    <section class="bg-slate-900 border border-slate-800 rounded-3xl p-6 sm:p-8 md:p-10 shadow-xl mb-6">
        <div class="mb-8 text-center sm:text-left flex flex-col sm:flex-row sm:items-center justify-between gap-5 border-b border-slate-800/60 pb-6">
            <div>
                <h2 class="text-xl md:text-2xl font-black text-white uppercase tracking-wide inline-flex items-center gap-3">
                    <span class="w-3 h-3 rounded-full bg-gradient-to-tr from-cyan-500 to-blue-500 animate-pulse"></span>
                    Tentative Blader Roster
                </h2>
                <p class="text-sm text-slate-400 mt-1 max-w-md mx-auto sm:mx-0">Current unconfirmed list of competitors expressing entry intent for Season 1</p>
            </div>

            <div class="bg-slate-950 px-5 py-2.5 rounded-xl border border-slate-800 text-xs font-bold text-slate-400 mx-auto sm:mx-0 shadow-inner tracking-wide uppercase whitespace-nowrap">
                Current Total Intent: <span class="text-cyan-400 text-sm font-black ml-1.5">{{ tentative_bladers|length }} Bladers</span>
            </div>
        </div>

        <div class="grid grid-cols-1 sm:grid-cols-2 md:grid-cols-3 gap-3 justify-center">
            {% for blader in tentative_bladers %}
                <div class="flex items-center justify-center p-3.5 bg-slate-950/60 rounded-xl border border-slate-800/80 hover:border-cyan-500/40 hover:bg-slate-950 transition-all duration-200 group">
                    <h3 class="font-bold text-slate-200 text-base tracking-wide group-hover:text-white transition-colors">{{ blader }}</h3>
                </div>
            {% endfor %}
        </div>
    </section>

    <!-- Governance Section -->
    <section class="bg-slate-900/80 backdrop-blur-sm border border-slate-800 rounded-3xl p-6 sm:p-8 md:p-10 shadow-2xl mb-12 md:mb-16">
        <div class="mb-8 text-center sm:text-left">
            <h2 class="text-xl md:text-2xl font-black text-white uppercase tracking-wide flex flex-col sm:flex-row items-center justify-center sm:justify-start gap-3">
                <span class="hidden sm:block w-3 h-3 rounded-sm bg-blue-500 rotate-45"></span>
                Official Rulesets & Governance
            </h2>
            <p class="text-sm text-slate-400 mt-3 leading-relaxed max-w-2xl">
                Review the official framework requirements linked below to ensure full competitive compliance before entering.
            </p>
        </div>

        <div class="grid grid-cols-1 sm:grid-cols-3 gap-4">

            <!-- Link 1 -->
            <a href="https://docs.google.com/document/d/1gDJ8HwERcYUK9SaMfJs6GMkSc_OFfl6D1pR_3Amqv3k/edit?tab=t.0#heading=h.kzgypszfov7"
               target="_blank" rel="noopener noreferrer"
               class="group flex flex-col p-5 bg-slate-950 rounded-2xl border border-slate-800 hover:border-cyan-500 hover:bg-slate-900 transition-all duration-300 hover:-translate-y-1 hover:shadow-[0_10px_20px_-10px_rgba(6,182,212,0.3)]">
                <div class="flex justify-between items-center mb-3">
                    <span class="text-xs font-black text-cyan-500 uppercase tracking-widest">Structure</span>
                    <svg class="w-4 h-4 text-slate-600 group-hover:text-cyan-400 transition-transform duration-300 group-hover:translate-x-1 group-hover:-translate-y-1" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M10 6H6a2 2 0 00-2 2v10a2 2 0 002 2h10a2 2 0 002-2v-4M14 4h6m0 0v6m0-6L10 14" /></svg>
                </div>
                <h3 class="text-base font-bold text-white group-hover:text-cyan-100 transition-colors mb-2">Tournament Organisation</h3>
                <p class="text-xs text-slate-500 leading-relaxed mt-auto">Bracket pairing configurations, check-ins, and schedule compliance.</p>
            </a>

            <!-- Link 2 -->
            <a href="https://worldbeyblade.org/Thread-Beyblade-X-Rules"
               target="_blank" rel="noopener noreferrer"
               class="group flex flex-col p-5 bg-slate-950 rounded-2xl border border-slate-800 hover:border-amber-500 hover:bg-slate-900 transition-all duration-300 hover:-translate-y-1 hover:shadow-[0_10px_20px_-10px_rgba(245,158,11,0.3)]">
                <div class="flex justify-between items-center mb-3">
                    <span class="text-xs font-black text-amber-500 uppercase tracking-widest">Gameplay</span>
                    <svg class="w-4 h-4 text-slate-600 group-hover:text-amber-400 transition-transform duration-300 group-hover:translate-x-1 group-hover:-translate-y-1" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M10 6H6a2 2 0 00-2 2v10a2 2 0 002 2h10a2 2 0 002-2v-4M14 4h6m0 0v6m0-6L10 14" /></svg>
                </div>
                <h3 class="text-base font-bold text-white group-hover:text-amber-100 transition-colors mb-2">Match & Game Rules</h3>
                <p class="text-xs text-slate-500 leading-relaxed mt-auto">Standard WBO launch rules, battle finish points, and valid gear interactions.</p>
            </a>

            <!-- Link 3 -->
            <a href="https://docs.google.com/document/d/1JeA-SBWd5BJSq3NSVcKrTHfy1vogIpWLBlUUDb6gAKs/edit?tab=t.0#heading=h.p2wfoud5z957"
               target="_blank" rel="noopener noreferrer"
               class="group flex flex-col p-5 bg-slate-950 rounded-2xl border border-slate-800 hover:border-red-500 hover:bg-slate-900 transition-all duration-300 hover:-translate-y-1 hover:shadow-[0_10px_20px_-10px_rgba(239,68,68,0.3)]">
                <div class="flex justify-between items-center mb-3">
                    <span class="text-xs font-black text-red-500 uppercase tracking-widest">Judging</span>
                    <svg class="w-4 h-4 text-slate-600 group-hover:text-red-400 transition-transform duration-300 group-hover:translate-x-1 group-hover:-translate-y-1" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M10 6H6a2 2 0 00-2 2v10a2 2 0 002 2h10a2 2 0 002-2v-4M14 4h6m0 0v6m0-6L10 14" /></svg>
                </div>
                <h3 class="text-base font-bold text-white group-hover:text-red-100 transition-colors mb-2">Judge Regulations</h3>
                <p class="text-xs text-slate-500 leading-relaxed mt-auto">Protocols for resolving ties, penalties, anomalies, and ruling protests.</p>
            </a>

        </div>
    </section>

    <footer class="mt-16 pt-8 border-t border-slate-900 text-center text-xs text-slate-500 space-y-2">
        <p>© 2026 Malta Beyblade Community. All Rights Reserved.</p>
    </footer>

</main>

</body>
</html>
