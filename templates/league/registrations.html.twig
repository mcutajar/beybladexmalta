<!DOCTYPE html>
<html lang="en" class="h-full bg-slate-950 text-slate-100">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>MBC League | Seasonal Registrations</title>
    <link rel="icon" type="image/x-icon" href="/assets/favicon.svg">
    {% block stylesheets %}
        {{ encore_entry_link_tags('app') }}
        <link rel="stylesheet" href="{{ asset('styles/app.css') }}">
    {% endblock %}
</head>
<body class="min-h-full font-sans antialiased selection:bg-cyan-500 selection:text-slate-950">

<div class="h-2 bg-gradient-to-r from-cyan-500 via-amber-500 to-red-500"></div>

<main class="max-w-5xl mx-auto px-4 py-8 md:py-12">

    <!-- Top Navigation Row -->
    <div class="mb-8 text-left">
        <a href="/" class="inline-flex items-center gap-2 px-3 py-1.5 rounded-lg bg-slate-900 border border-slate-800 text-xs font-semibold text-slate-400 hover:text-white hover:border-slate-700 transition-colors">
            ⬅ Return to Hub
        </a>
    </div>

    <!-- Centered Hero Title Block (Matches Standings Header Style) -->
    <header class="text-center mb-12 space-y-3">
        <div class="flex justify-center">
            <span class="inline-flex items-center px-3 py-1 rounded-full text-xs font-bold bg-cyan-950 text-cyan-400 border border-cyan-800/60 uppercase tracking-wider">
                Financial Clearance System
            </span>
        </div>
        <h1 class="text-4xl sm:text-6xl font-black tracking-tight text-white uppercase leading-none">
            Malta Community Beyblade <br>
            <span class="text-transparent bg-clip-text bg-gradient-to-r from-amber-400 to-red-500">Paid Registrations</span>
        </h1>
        <p class="text-slate-400 text-sm sm:text-base font-medium max-w-xl mx-auto">
            For <strong>the players</strong> By <strong>the players</strong>
        </p>
    </header>

    <!-- Content Area Container -->
    <div class="space-y-12">
        {% for season_name, players in grouped_payments %}

            <!-- Main Dashboard Card Component wrapper (Matches Preseason Standings wrapper) -->
            <div class="bg-gradient-to-b from-slate-900 to-slate-950 border border-slate-800/80 rounded-2xl p-6 md:p-8 shadow-2xl space-y-6">

                <!-- Inner Dashboard Header Layout with Side Badge -->
                <div class="flex flex-col sm:flex-row sm:items-center justify-between gap-4 pb-2">
                    <div class="space-y-1">
                        <span class="inline-flex items-center gap-1 text-[10px] px-2 py-0.5 rounded font-extrabold bg-cyan-500/10 text-cyan-400 border border-cyan-500/20 uppercase tracking-wider">
                            🔥 Active Season
                        </span>
                        <h2 class="text-2xl font-black text-white uppercase tracking-tight">{{ season_name }}</h2>
                        <p class="text-xs text-slate-400">Verified entry ledger tracking real clearance distributions.</p>
                    </div>
                </div>

                <!-- Clean Standings Table Architecture -->
                <div class="overflow-x-auto rounded-xl border border-slate-800/60 bg-slate-950/40">
                    <table class="w-full text-left border-collapse text-sm">
                        <thead class="bg-slate-900/60 border-b border-slate-800 text-slate-400 text-xs font-bold uppercase tracking-wider select-none">
                        <tr>
                            <th scope="col" class="px-4 py-4 text-center w-16">#</th>
                            <th scope="col" class="px-6 py-4">Blader Name</th>
                            <th scope="col" class="px-6 py-4 text-right w-36">Status</th>
                        </tr>
                        </thead>
                        <tbody class="divide-y divide-slate-800/40">
                        {% for p in players %}
                            <tr class="hover:bg-slate-800/20 transition-colors group">

                                <!-- Simple Row Number Counter Column -->
                                <td class="px-4 py-4 text-center whitespace-nowrap font-mono font-bold text-slate-500 text-xs">
                                    {{ loop.index }}
                                </td>

                                <!-- Bold Blader Profile Identification Row Link -->
                                <td class="px-6 py-4 whitespace-nowrap">
                                    <a href="{{ path('player_season_details', {'slug': p.season_slug, 'id': p.player_id}) }}" class="text-slate-200 font-bold text-sm tracking-wide group-hover:text-cyan-400 focus:text-cyan-400 outline-none transition-colors">
                                        {{ p.player_name }}
                                    </a>
                                </td>

                                <!-- Aligned Entry Tag -->
                                <td class="px-6 py-4 text-right whitespace-nowrap">
                                        <span class="inline-flex items-center gap-1 text-[10px] px-2.5 py-1 rounded font-black bg-emerald-500/10 text-emerald-400 border border-emerald-500/20 uppercase tracking-wider select-none">
                                            Paid ✓
                                        </span>
                                </td>

                            </tr>
                        {% endfor %}
                        </tbody>
                    </table>
                </div>

            </div>
        {% else %}
            <!-- Standings Style Empty State Layout Card -->
            <div class="max-w-md mx-auto bg-gradient-to-b from-slate-900 to-slate-950 border border-slate-800 rounded-2xl p-10 text-center shadow-xl">
                <div class="w-12 h-12 bg-slate-950 border border-slate-800 rounded-xl flex items-center justify-center mx-auto mb-4 text-xl">📋</div>
                <h3 class="text-sm font-black text-white uppercase tracking-wider">Ledger Unpopulated</h3>
                <p class="text-xs text-slate-500 italic mt-2 leading-relaxed">
                    No verified entry payments or seasonal registrations have been processed in the database ledger container yet.
                </p>
            </div>
        {% endfor %}
    </div>

    <!-- Persistent Global Copyright Footer -->
    <footer class="mt-24 pt-8 border-t border-slate-900 text-center text-xs text-slate-600 tracking-wide">
        <p>© 2026 Malta Beyblade Community. All Rights Reserved.</p>
    </footer>

</main>

</body>
</html>
