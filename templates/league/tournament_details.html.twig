<!DOCTYPE html>
<html lang="en" class="h-full bg-slate-950 text-slate-100">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>{{ tournament.title }} | Standings</title>
    <link rel="icon" type="image/x-icon" href="/assets/favicon.svg">
    {% block stylesheets %}
        {{ encore_entry_link_tags('app') }}
        <link rel="stylesheet" href="{{ asset('styles/app.css') }}">
    {% endblock %}
</head>
<body class="min-h-full font-sans antialiased selection:bg-cyan-500 selection:text-slate-950">

<div class="h-2 bg-gradient-to-r from-amber-500 via-red-500 to-cyan-500"></div>

<main class="max-w-5xl mx-auto px-4 py-12 md:py-20">

    <div class="mb-6 text-left">
        <a href="{{ path('preseason') }}" class="inline-flex items-center gap-2 px-3 py-1.5 rounded-lg bg-slate-900 border border-slate-800 text-xs font-semibold text-slate-400 hover:text-white hover:border-slate-700 transition-colors">
            ⬅ Return to Preseason Leaderboard
        </a>
    </div>

    <header class="text-center mb-12 space-y-2">
        <span class="inline-flex items-center gap-1.5 px-3 py-1 rounded-full text-xs font-semibold bg-amber-500/10 text-amber-400 ring-1 ring-inset ring-amber-500/20 tracking-wider uppercase">
            Official Event Record
        </span>
        <h1 class="text-4xl font-black tracking-tight text-white uppercase">{{ tournament.title }}</h1>
        <p class="text-slate-400 text-sm font-mono">Held on {{ tournament.heldOn|date('Y-m-d') }}</p>
    </header>

    <div class="bg-slate-900 border border-slate-800 rounded-3xl p-4 sm:p-8 shadow-2xl w-full">
        <div class="overflow-x-auto">
            <table class="w-full text-left text-sm border-collapse">
                <thead>
                <tr class="border-b border-slate-800 text-xs font-bold uppercase tracking-wider text-slate-400 bg-slate-950/40">
                    <th class="px-3 sm:px-6 py-4 text-center w-16">Rank</th>
                    <th class="px-3 sm:px-6 py-4">Blader Name</th>
                    <th class="px-3 sm:px-6 py-4 text-center">Base F1 Pts</th>
                    <th class="px-3 sm:px-6 py-4 text-center">KO/Bonus Pts</th>
                    <th class="px-3 sm:px-6 py-4 text-right text-cyan-400 font-bold pr-4">Total</th>
                </tr>
                </thead>
                <tbody class="divide-y divide-slate-800/40 text-slate-300 font-medium">
                {% for row in standings %}
                    <tr class="hover:bg-slate-800/30 transition-colors">
                        <td class="px-3 sm:px-6 py-4 text-center font-bold text-slate-500 text-xs">
                            {{ loop.index }}
                        </td>
                        <td class="px-3 sm:px-6 py-4">
                            <a href="{{ path('player_preseason_details', {'id': row.player_id}) }}" class="text-white font-bold hover:text-cyan-400 transition-colors">
                                {{ row.player_name }}
                            </a>
                        </td>
                        <td class="px-3 sm:px-6 py-4 text-center text-slate-300">{{ row.f1_points }}</td>
                        <td class="px-3 sm:px-6 py-4 text-center">
                            {% if row.bonus_points > 0 %}
                                <span class="text-emerald-400 font-extrabold text-xs">+{{ row.bonus_points }}</span>
                            {% else %}
                                <span class="text-slate-600">—</span>
                            {% endif %}
                        </td>
                        <td class="px-3 sm:px-6 py-4 text-right font-black text-white pr-4">{{ row.total_points }} <span class="text-xs font-normal text-slate-500">pts</span></td>
                    </tr>
                {% else %}
                    <tr>
                        <td colspan="5" class="px-3 sm:px-6 py-12 text-center text-sm text-slate-500 italic">No match details recorded for this tournament.</td>
                    </tr>
                {% endfor %}
                </tbody>
            </table>
        </div>
    </div>

</main>
</body>
</html>
